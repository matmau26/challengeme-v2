{
  "expo": {
    "name": "challengeme-v2",
    "slug": "challengeme-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "challengeme",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.challengeme.proveyourself",
      "entitlements": {
        "aps-environment": "development"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application accède à vos photos pour importer une preuve.",
          "cameraPermission": "L'application accède à l'appareil photo pour filmer ou photographier une preuve.",
          "microphonePermission": "L'application accède au micro pour enregistrer l'audio des vidéos."
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development",
          "devTeam": "N8T95UXCS9",
          "iPhoneDeploymentTarget": "15.1"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8af273a5-e896-4078-80f0-b2af0cd38c26"
      }
    }
  }
}
